{
  "name": "skript-lsp",
  "displayName": "Skript LSP",
  "description": "Language support for Skript (Minecraft scripting) via skript-lsp",
  "version": "0.1.0",
  "publisher": "skript-studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skript-studio/skript-lsp.git"
  },
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "skript",
    "minecraft",
    "lsp",
    "language-server"
  ],
  "activationEvents": [
    "onLanguage:skript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "skript",
        "aliases": [
          "Skript",
          "skript"
        ],
        "extensions": [
          ".sk"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "skript",
        "scopeName": "source.skript",
        "path": "./syntaxes/skript.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Skript LSP",
      "properties": {
        "skript-lsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the skript-lsp binary. Leave empty to use the bundled binary, or set a custom path."
        },
        "skript-lsp.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "trace",
            "debug",
            "info",
            "warn",
            "error"
          ],
          "description": "Log level for the LSP server (written to stderr)."
        },
        "skript-lsp.maxCompletions": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of completion items returned per request."
        }
      }
    }
  },
  "scripts": {
    "compile": "bun build --outdir out --target node --external vscode --format cjs --minify src/extension.ts",
    "typecheck": "tsc --noEmit",
    "watch": "bun --watch build --outdir out --target node --external vscode --format cjs src/extension.ts",
    "download-cache": "curl -s https://skripthub.net/api/v1/addonsyntaxlist/ | node normalize-cache.mjs",
    "build:binary": "cargo build -p skript-lsp --release && Copy-Item -Force ..\\..\\target\\release\\skript-lsp.exe bin\\",
    "prepublish": "bun run build:binary && bun run compile"
  },
  "author": "",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/skript-studio/skript-lsp/issues"
  },
  "homepage": "https://github.com/skript-studio/skript-lsp#readme",
  "dependencies": {
    "@types/vscode": "^1.125.0",
    "vscode-languageclient": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3"
  }
}
